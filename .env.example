# ── 数据库 ──────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./livescope.db

# ── TikTok 采集（必填，解除速率限制） ─────────────
# 免费注册：https://www.eulerstream.com/pricing
EULERSTREAM_API_KEY=

# ── 抖音采集（可选，提升稳定性） ──────────────────
# 从浏览器 Cookie 中获取以下字段
DOUYIN_COOKIE=ttwid=xxx; __ac_nonce=xxx; sessionid=xxx

# ── 采集参数 ──────────────────────────────────────
# 批量写入数据库间隔（秒）
BATCH_WRITE_INTERVAL=2
# 消息去重缓存大小
DEDUP_CACHE_SIZE=5000
